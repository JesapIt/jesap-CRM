# Example of environment variables
# To run locally, project already contains safe patterns defined in the settings.py
# But if you must test as production, copy this file and rename it to .env, then change the values below:

DEBUG=True
SECRET_KEY=secret_development_key_goes_here
ALLOWED_HOSTS=127.0.0.1,localhost

# Database
# If DATABASE_URL is set, Django uses PostgreSQL (e.g. Supabase). Omit it or set USE_SQLITE=true to use db.sqlite3.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Optional: force SQLite even when DATABASE_URL is present (offline dev)
# USE_SQLITE=true
# If the pooler host fails DNS/SSL, try the direct DB host (db.<project-ref>.supabase.co)
# SUPABASE_DIRECT_DB_HOST=

# Email (SMTP — Google Workspace)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587


EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@jesap.it
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=JESAP CRM <noreply@jesap.it>